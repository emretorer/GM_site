# Optional: leave empty if production uses the same domain under /api.
# If you use a separate backend service, set this to the backend origin (not the frontend URL).
VITE_API_BASE_URL=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=
# Enable frontend mock backend/auth layer when no real backend or Firebase exists.
VITE_USE_MOCK_DATA=false
